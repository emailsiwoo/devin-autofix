# Devin API
DEVIN_API_KEY=your-devin-api-key
DEVIN_ORG_ID=your-devin-org-id

# GitHub webhook secret (set the same value when creating the webhook)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# GitHub personal access token (needed for Dependabot alerts API)
GITHUB_TOKEN=your-github-token

# Target repository and trigger label
TARGET_REPO=emailsiwoo/superset-demo
TRIGGER_LABEL=devin-autofix

# Polling interval in seconds (how often to check Devin session status)
POLL_INTERVAL_SECONDS=60

# Scheduled daily scan time (UTC, 24-hour format)
SCAN_HOUR_UTC=8
SCAN_MINUTE_UTC=0
